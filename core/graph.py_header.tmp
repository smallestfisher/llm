# ==========================================
# 1. 定义状态总线 (加入 chat_history)
# ==========================================
class GraphState(TypedDict):
    question: str
    chat_history: Annotated[list, operator.add] 
    table_schema: str
    normalized_question: str
    lexicon_hits: list
    intent: str
    intent_confidence: float
    intent_filters: dict
    refined_filters: dict
    sql_query: str
    sql_error: str
    db_result: str
    final_answer: str
    retry_count: int
    chart_data: dict # 🔴 存放可视化图表 JSON
