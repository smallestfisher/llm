{
  "daily_inventory": {
    "description": "每日库存快照表，记录各仓库各产品的可用库存和安全库存。时间粒度为日。",
    "columns": ["id", "report_date (上报日期)", "factory_code (工厂代码)", "warehouse_code (仓库代码)", "product_code (产品编码)", "available_qty (可用库存量)", "safety_stock (安全库存值)"],
    "date_col": "report_date"
  },
  "daily_schedule": {
    "description": "每日排产计划表，记录各产线各产品的目标产量。时间粒度为日。",
    "columns": ["id", "work_date (排产日期)", "factory_code", "line_code (产线代码)", "product_code", "shift (班次: Day/Night)", "target_qty (计划产出量)"],
    "date_col": "work_date"
  },
  "monthly_plan_approved": {
    "description": "已审批的月度生产计划表，作为考核基准。时间粒度为月。",
    "columns": ["id", "plan_month (计划月份, 格式 YYYY-MM)", "factory_code", "product_code", "target_glass_qty (玻璃目标量)", "target_panel_qty (面板目标量)", "version (版本号)"],
    "month_col": "plan_month"
  },
  "oms_inventory": {
    "description": "OMS订单系统库存表，包含在途和客户Hub库存。用于计算齐套性。",
    "columns": ["id", "report_date", "product_code", "customer_name (客户名称)", "in_transit_qty (在途量)", "hub_qty (自备仓量)", "customer_hub_qty (客户仓量)"],
    "date_col": "report_date"
  },
  "p_demand": {
    "description": "生产需求表(Production Demand)，对应工厂端的交付承诺。时间粒度为月。",
    "columns": ["id", "p_demand_no (生产需求号)", "v_demand_no (关联客户需求号)", "product_code", "commit_month (承诺月份)", "commit_qty (承诺交付量)", "status (状态: 0-草稿, 1-已发布)"],
    "month_col": "commit_month"
  },
  "product_attributes": {
    "description": "产品属性维表，包含技术族、应用领域、交付周期等静态信息。",
    "columns": ["id", "product_code", "tech_family (技术族: 如ADS/IPS)", "application (应用领域: 如Mobile/TV/IT)", "std_lead_time_days (标准交付周期)", "moq (起订量)", "life_cycle (生命周期: NPI/MP/EOL)"]
  },
  "product_mapping": {
    "description": "产品生产关系映射表，记录产品与玻璃基板尺寸、切割效率及工厂偏好。",
    "columns": ["id", "product_code", "glass_substrate_size (基板尺寸)", "cut_efficiency (切割效率)", "preferred_factory (偏好工厂)", "alternative_factory (备选工厂)"]
  },
  "production_actuals": {
    "description": "生产实绩表，记录产线实际产出、投入和不良情况。时间粒度为日。",
    "columns": ["id", "work_date (生产日期)", "line_code", "product_code", "input_qty (投入量)", "output_qty (产出量)", "defect_qty (不良量)", "yield_rate (良率, 小数格式)"],
    "date_col": "work_date"
  },
  "sales_financial_perf": {
    "description": "销售与财务表现表，记录销量、单价、营收和毛利。时间粒度为月。",
    "columns": ["id", "report_month (报告月份)", "product_code", "sales_qty (销量)", "unit_price_usd (美金单价)", "revenue_usd (营收)", "gross_margin_pct (毛利率)"],
    "month_col": "report_month"
  },
  "v_demand": {
    "description": "客户需求表(Vendor/Customer Demand)，记录原始市场预测。时间粒度为月。",
    "columns": ["id", "demand_no (需求号)", "customer_name", "product_code", "forecast_month (预测月份)", "forecast_qty (预测数量)", "create_time"],
    "month_col": "forecast_month"
  },
  "weekly_rolling_plan": {
    "description": "周滚动计划表，介于月计划与日排产之间。包含调整原因。",
    "columns": ["id", "plan_month", "week_no (周次, 1-4)", "factory_code", "product_code", "planned_qty (计划量)", "adjust_reason (调整原因)"],
    "month_col": "plan_month"
  },
  "work_in_progress": {
    "description": "在制快照表(WIP)，记录当前产线上的半成品分布。实时性较高。",
    "columns": ["id", "lot_id (批次号)", "factory_code", "product_code", "current_process (当前工序)", "wip_qty (在制数量)", "hold_flag (是否挂起: 0/1)", "update_time"],
    "date_col": "update_time"
  }
}
